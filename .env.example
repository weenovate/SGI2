# ---------------------------------------------------------------------------
# SGI - Variables de entorno
# Copiar a `.env` (no commitear) y completar.
# ---------------------------------------------------------------------------

# --- App ---
NODE_ENV=development
NEXT_PUBLIC_APP_NAME="SGI - FuENN"

# Hosts (en prod: subdominios reales)
PUBLIC_HOST=inscripciones.localhost
BACKOFFICE_HOST=sgi.localhost
APP_URL=http://localhost:3000

# --- Base de datos (MySQL) ---
DATABASE_URL="mysql://USER:PASS@HOST:3306/sgi"

# --- Auth.js ---
# Generar con `openssl rand -base64 32`
AUTH_SECRET="cambiar-en-produccion"
# La URL canónica para callbacks (puede ser http://localhost:3000 en dev)
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST=true

# --- Storage privado (FUERA del webroot, fuera de public/) ---
# En cPanel típicamente: /home/<cpanel-user>/sgi-uploads
UPLOADS_DIR="./uploads"

# --- Email (Resend) ---
RESEND_API_KEY=""
EMAIL_FROM="SGI FuENN <noreply@fuenn.com>"
EMAIL_REPLY_TO="contacto@fuenn.com"

# --- Cron (cPanel hace HTTP a /api/cron/<task> con este secret) ---
CRON_SECRET="cambiar-en-produccion"

# --- OCR (Tesseract) ---
# Carpeta donde tesseract.js cachea los traineddata. Mejor fuera del webroot.
TESSDATA_DIR="./tessdata"
TESSERACT_LANG="spa"
